# =========================
# Django Core
# =========================
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =========================
# Database
# =========================
# Leave DATABASE_URL empty to use local SQLite (development default).
# Example for PostgreSQL (production):
# DATABASE_URL=postgres://user:password@host:5432/indusmind_ai
DATABASE_URL=

# =========================
# Document Upload
# =========================
# Maximum accepted upload size, in megabytes.
DOCUMENT_MAX_UPLOAD_SIZE_MB=50

# =========================
# AI / LLM Providers
# =========================
GOOGLE_API_KEY=

# =========================
# Vector Database (ChromaDB)
# =========================
CHROMA_PERSIST_DIRECTORY=chroma_db
CHROMA_COLLECTION_NAME=indusmind_documents
CHROMA_BATCH_SIZE=100
CHROMA_SEARCH_K=10
CHROMA_SIMILARITY_THRESHOLD=0.0
CHROMA_MAX_RESULTS=50

# =========================
# Knowledge Graph
# =========================
KG_ENTITY_CONFIDENCE_THRESHOLD=0.3
KG_RELATIONSHIP_CONFIDENCE_THRESHOLD=0.3
KG_MAX_ENTITIES_PER_DOCUMENT=500
KG_MAX_RELATIONSHIPS_PER_DOCUMENT=1000
KG_DEDUPLICATION_ENABLED=True
KG_PERSIST_PATH=knowledge_graph.pkl

# =========================
# Computer Vision / Drawing Analysis
# =========================
VISION_OCR_CONFIDENCE_THRESHOLD=0.3
VISION_SYMBOL_CONFIDENCE_THRESHOLD=0.5
VISION_MAX_EQUIPMENT_PER_DRAWING=200
VISION_MAX_RELATIONSHIPS_PER_DRAWING=500

# =========================
# RAG Pipeline / Agent Orchestrator
# =========================
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.0
RAG_MAX_CONTEXT_TOKENS=4000
RAG_MAX_RESPONSE_TOKENS=2000
RAG_LLM_MODEL=gemini-1.5-flash
RAG_TEMPERATURE=0.3
RAG_LLM_TIMEOUT_SECONDS=30
RAG_LLM_MAX_RETRIES=3
RAG_WEIGHT_SEMANTIC=0.4
RAG_WEIGHT_GRAPH=0.25
RAG_WEIGHT_METADATA=0.15
RAG_WEIGHT_RECENCY=0.1
RAG_WEIGHT_CONFIDENCE=0.1

# =========================
# OCR
# =========================
# Path to the Tesseract binary. Required on Windows; usually auto-detected on Linux/Mac.
TESSERACT_CMD=
# Set to False to disable OCR fallback entirely during document parsing.
OCR_ENABLED=True

# =========================
# Document Chunking
# =========================
CHUNKING_CHUNK_SIZE=1000
CHUNKING_CHUNK_OVERLAP=150
CHUNKING_MAX_CHUNK_LENGTH=2000
CHUNKING_MIN_CHUNK_LENGTH=20

# =========================
# File Storage
# =========================
MEDIA_ROOT=media
UPLOADS_ROOT=uploads

# =========================
# Embedding Generator
# =========================
# Google Gemini embedding model identifier.
EMBEDDING_MODEL_NAME=models/embedding-001
# Number of chunks to embed per API call.
EMBEDDING_BATCH_SIZE=20
# Maximum retry attempts for transient API failures.
EMBEDDING_MAX_RETRIES=3
# Per-request timeout in seconds.
EMBEDDING_TIMEOUT_SECONDS=30
# Maximum parallel embedding requests (reserved for future async support).
EMBEDDING_MAX_CONCURRENT_REQUESTS=5
# Maximum character length for a single chunk's text before truncation.
EMBEDDING_MAX_CHUNK_TEXT_LENGTH=10000
